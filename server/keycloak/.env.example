# Copy this file to .env and replace every password/secret before running:
# docker compose up -d

# Images
# Pin this before production instead of relying on latest.
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:latest
POSTGRES_IMAGE=postgres:16-alpine

# Keycloak bootstrap admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-long-random-admin-password

# Keycloak database
KEYCLOAK_DATABASE=keycloak
KEYCLOAK_DATABASE_USER=keycloak
KEYCLOAK_DATABASE_PASSWORD=replace-with-a-long-random-database-password

# Local HTTP endpoint
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_PROXY_HEADERS=xforwarded
KEYCLOAK_LOG_LEVEL=INFO

# AgentNexus realm/client planning values.
# Use these when creating the Keycloak realm and OIDC client in the admin console
# or in a future realm import file.
AGENTNEXUS_REALM=agentnexus
AGENTNEXUS_PUBLIC_BASE_URL=http://localhost:4321
AGENTNEXUS_OIDC_CLIENT_ID=agentnexus-web
AGENTNEXUS_OIDC_CLIENT_SECRET=replace-if-confidential-client-is-used

# Upstream SSO providers to configure inside the AgentNexus realm.
# Keep real client secrets only in .env or a secret manager.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
