# Copy this file to .env and replace every password/secret before running:
# docker compose up -d

# Host port published by the Directus service.
DIRECTUS_HOST_PORT=8055

# Host UID/GID used by the Directus container for bind-mounted folders.
# Set these to your local user/group IDs if uploads/extensions are not writable.
# Example: run `id -u` and `id -g` on the host.
# A one-shot compose service applies these values to ./uploads and ./extensions.
DIRECTUS_UID=1000
DIRECTUS_GID=1000

# Directus security.
# Generate a long random value for SECRET.
SECRET=replace-with-a-long-random-directus-secret
REFRESH_TOKEN_COOKIE_NAME=agentnexus_refresh_token
SESSION_COOKIE_NAME=agentnexus_session_token

# Database credentials shared by the database and directus services.
# DB_HOST remains fixed to the neighbouring `database` container in docker-compose.yml.
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus

# CORS.
# Enabled only for development purposes. Keep them default otherwise
#CORS_ENABLED=true
#CORS_ORIGIN=true
#CORS_METHODS=GET,POST,PATCH,DELETE
#CORS_ALLOWED_HEADERS=Content-Type,Authorization
#CORS_EXPOSED_HEADERS=Content-Range
#CORS_CREDENTIALS=true
#CORS_MAX_AGE=18000

# Bootstrap admin.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-admin-password

# Public deployment URL.
PUBLIC_URL=http://localhost:8055

# Extensions.
EXTENSIONS_AUTO_RELOAD=true

# Email transport.
EMAIL_FROM=admin@example.com
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_POOL=true
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=replace-with-smtp-user
EMAIL_SMTP_PASSWORD=replace-with-smtp-password

# Uploads/imports/realtime.
# IMPORT_IP_DENY_LIST equals blank to allow flows access resources from directus' own API endpoints
TUS_ENABLED=true
WEBSOCKETS_ENABLED=true
#IMPORT_IP_DENY_LIST=
